{
	"$schema": "https://raw.githubusercontent.com/zheka2304/innercore-mod-toolchain/develop/toolchain/schemas/make.schema.json",
	"resources": [
		{
			"path": "assets",
			"type": "resource_directory"
		},
		{
			"path": "assets/gui",
			"type": "gui"
		}
	],
	"project": {
		"composite": false
	},
	"sources": [
		{
			"source": "code",
			"target": "main.js",
			"type": "main",
			"language": "typescript"
		},
		{
			"source": "launcher.js",
			"type": "launcher",
			"language": "javascript"
		},
		{
			"source": "library/*",
			"type": "library",
			"language": "typescript"
		}
	],
	"additional": [
		{
			"source": "config.json",
			"targetDir": "."
		},
		{
			"source": "config.info.json",
			"targetDir": "."
		}
	],
    "compile": [
        {
            "type": "java",
            "source": "java"
        }
    ],
	"info": {
		"name": "Fireflies",
		"author": "ArtemKot",
		"version": "2025",
		"description": "Мод-библиотека, добавляющая более удобное api для разработки модификаций объектно-ориентированным методом. Так же дополняет встроенное, добавляя возможности, которых раньше не было.",
		"icon": "mod_icon.png",
        "javaBoot": "com.artemkot4.fireflies.Fireflies"
	},
	"api": "CoreEngine",
	"linkNative": [
		"minecraftpe",
		"innercore",
		"nativejs"
	],
	"excludeFromRelease": [],
	"tsconfig": {
		"strict": false,
		"strictNullChecks": false,
		"ignoreDeprecations": "6.0",
		"downlevelIteration": false
	},
	"environment": {
  		"JAVA_HOME": "C:\\Program Files\\Eclipse Adoptium\\jdk-8.0.492.9-hotspot\\"
 	}
}